{
  "expo": {
    "name": "Foundly",
    "slug": "startupmatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a3e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.startupmatch.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1a3e"
      },
      "package": "com.foundly.app",
      "versionCode": 1
    },
    "scheme": "startupmatch",
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b1d4407b-bd8d-4de9-822c-4136c2508424"
      }
    },
    "owner": "phucgiotai"
  }
}
